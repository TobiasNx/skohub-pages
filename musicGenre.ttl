@prefix dct: <http://purl.org/dc/terms/>.
@prefix skos: <http://www.w3.org/2004/02/skos/core#>.
@prefix vann: <http://purl.org/vocab/vann/>.
@prefix bla: <https://w3id.org/>.

bla:
    a skos:ConceptScheme;
    dct:title "Music Genre"@de;
    vann:preferredNamespaceUri bla:;
    skos:hasTopConcept bla:103b4, bla:2963f, bla:4082a.
bla:103b4
    a skos:Concept;
    skos:prefLabel "Classical"@en, "Klassik"@de;
    skos:topConceptOf bla: .
bla:1f55d a skos:Concept; skos:inScheme bla: .

bla:2963f
    a skos:Concept;
    skos:narrower bla:1f55d, bla:8b9de;
    skos:prefLabel "Rock"@en, "Rock"@de;
    skos:topConceptOf bla: .
bla:4082a
a skos:Concept; skos:prefLabel "Electronic"@en, "Electro"@de; skos:topConceptOf bla: .
bla:8b9de
    a skos:Concept;
    skos:broader bla:2963f;
    skos:inScheme bla:;
    skos:prefLabel "Metal"@de, "Metal"@en.
